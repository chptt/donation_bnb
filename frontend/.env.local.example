# Deployed contract address (from: cd blockchain && npm run deploy:testnet)
NEXT_PUBLIC_CONTRACT_ADDRESS=your_deployed_contract_address_here

# BNB Chain Testnet
NEXT_PUBLIC_BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545/
NEXT_PUBLIC_BLOCK_EXPLORER=https://testnet.bscscan.com

# Pinata IPFS — get free keys at https://pinata.cloud
# Option A: JWT (recommended)
NEXT_PUBLIC_PINATA_JWT=your_pinata_jwt_token

# Option B: Legacy API key + secret (use A or B, not both)
NEXT_PUBLIC_PINATA_API_KEY=your_pinata_api_key
NEXT_PUBLIC_PINATA_SECRET_KEY=your_pinata_secret_key

# IPFS gateway (optional, defaults to Pinata public gateway)
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs/
